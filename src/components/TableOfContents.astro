---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{toc.length > 0 && (
  <aside class="toc">
    <div class="toc-label">on this page ~</div>
    <ul class="toc-list">
      {toc.map((h) => (
        <li>
          <a href={`#${h.slug}`} class:list={[{ 'depth-3': h.depth === 3 }]} data-section={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script>
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-list a[data-section]');
  const headings = Array.from(tocLinks).map((link) => {
    const id = link.dataset.section!;
    return { link, el: document.getElementById(id) };
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          tocLinks.forEach((l) => l.classList.remove('active'));
          const match = headings.find((h) => h.el === entry.target);
          if (match) match.link.classList.add('active');
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );

  headings.forEach((h) => { if (h.el) observer.observe(h.el); });
</script>

<style>
  .toc { position: sticky; top: 80px; padding-top: 4px; }
  .toc-label {
    font-family: var(--hand); font-size: 15px; color: var(--text-4);
    margin-bottom: 14px; transform: rotate(-0.5deg);
  }
  .toc-list { list-style: none; display: flex; flex-direction: column; }
  .toc-list li { margin: 0; }
  .toc-list a {
    display: block; padding: 6px 0 6px 16px; font-family: var(--body); font-size: 12.5px; font-weight: 400;
    color: var(--text-4); text-decoration: none; border-left: 1.5px solid var(--border);
    transition: all var(--ease); line-height: 1.45;
  }
  .toc-list a:hover { color: var(--text-2); border-color: var(--text-3); }
  .toc-list a.active { color: var(--accent); border-color: var(--accent); font-weight: 500; }
  .toc-list a.depth-3 { padding-left: 28px; font-size: 11.5px; }
</style>
