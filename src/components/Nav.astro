---
const pathname = Astro.url.pathname;
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">chirag jog<span class="logo-dot"></span></a>
    <div class="nav-links">
      <a href="/" class:list={[{ active: pathname === '/' }]}>Writing</a>
      <a href="/about" class:list={[{ active: pathname === '/about' }]}>About</a>
      <a href="https://github.com/chiragjog" target="_blank" rel="noopener">GitHub</a>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">☀</button>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('themeToggle')!;
  const update = () => {
    const isDark = document.documentElement.classList.contains('dark');
    toggle.textContent = isDark ? '☾' : '☀';
  };
  update();
  toggle.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    update();
  });
</script>

<style>
  nav {
    position: sticky; top: 0; z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    border-bottom: 1px solid var(--border-light);
    transition: all var(--ease);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
  }
  .nav-inner {
    max-width: var(--wide-w); margin: 0 auto; padding: 14px 32px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--heading); font-size: 20px; font-weight: 500;
    color: var(--text); text-decoration: none; letter-spacing: -0.02em;
    display: flex; align-items: baseline; gap: 3px;
  }
  .logo-dot {
    display: inline-block; width: 6px; height: 6px; border-radius: 99px;
    background: var(--accent); margin-left: 1px; position: relative; top: -1px;
  }
  .nav-links { display: flex; align-items: center; gap: 24px; }
  .nav-links a {
    font-family: var(--body); font-size: 14px; font-weight: 450;
    color: var(--text-3); text-decoration: none; transition: color var(--ease);
    position: relative;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--text); font-weight: 600; }
  .nav-links a.active::after {
    content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
    height: 2px; background: var(--accent); border-radius: 99px;
  }
  .theme-toggle {
    width: 34px; height: 34px; border-radius: 99px; border: 1px solid var(--border);
    background: var(--bg-warm); cursor: pointer; display: flex; align-items: center;
    justify-content: center; font-size: 14px; transition: all var(--ease); color: var(--text-3);
  }
  .theme-toggle:hover { border-color: var(--accent-border); color: var(--accent); transform: rotate(15deg); }
  @media (max-width: 860px) { .nav-inner { padding: 12px 20px; } }
</style>
