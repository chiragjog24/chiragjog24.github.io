---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  slug: string;
  readingTime?: number;
  featured?: boolean;
}

const { title, description, pubDate, category, tags, slug, readingTime, featured } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class:list={['post-item', { featured }]}
  data-cat={category}
>
  <div>
    <div class="post-meta">
      <span class="post-cat">{category}</span>
      <span class="post-dot"></span>
      <span>{formattedDate}</span>
      {readingTime && (
        <>
          <span class="post-dot"></span>
          <span>{readingTime} min read</span>
        </>
      )}
    </div>
    <div class="post-title">{title}</div>
    <div class="post-excerpt">{description}</div>
    <div class="post-tags">
      {tags.map((tag) => <span class="post-tag">{tag}</span>)}
    </div>
  </div>
  {!featured && readingTime && <div class="post-reading">{readingTime} min</div>}
</a>

<style>
  .post-item {
    display: grid; grid-template-columns: 1fr auto; gap: 20px;
    padding: 26px 0; border-bottom: 1px solid var(--border-light);
    cursor: pointer; align-items: start; transition: opacity var(--ease);
    text-decoration: none; color: inherit;
  }
  .post-item:first-child { border-top: 1px solid var(--border-light); }
  .post-item:hover .post-title { color: var(--accent); }
  .post-meta {
    display: flex; align-items: center; gap: 10px; margin-bottom: 5px;
    font-family: var(--body); font-size: 12px; color: var(--text-3); font-weight: 400;
  }
  .post-cat { font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); font-size: 11px; }
  .post-dot { width: 3px; height: 3px; border-radius: 99px; background: var(--text-4); }
  .post-title {
    font-family: var(--heading); font-size: 21px; font-weight: 500; letter-spacing: -0.015em;
    line-height: 1.3; transition: color var(--ease); margin-bottom: 5px;
  }
  .post-excerpt { font-size: 15px; color: var(--text-2); line-height: 1.65; max-width: 600px; font-weight: 400; }
  .post-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .post-tag {
    font-family: var(--body); font-size: 10.5px; font-weight: 500;
    padding: 3px 10px; border-radius: 4px; background: var(--tag-bg); color: var(--tag-text);
  }
  .post-reading { font-family: var(--body); font-size: 13px; color: var(--text-4); white-space: nowrap; padding-top: 6px; font-weight: 400; }
  .featured { grid-template-columns: 1fr; padding: 32px 0; }
  .featured .post-title { font-size: 28px; }
</style>
