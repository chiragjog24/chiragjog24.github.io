---
import Base from '@/layouts/Base.astro';
---

<Base title="404 — Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>This page wandered off somewhere. Try heading <a href="/">home</a>.</p>
  </div>
</Base>

<style>
  .not-found {
    max-width: var(--max-w); margin: 0 auto; padding: 120px 32px;
    text-align: center;
  }
  .not-found h1 {
    font-family: var(--heading); font-size: 72px; font-weight: 500;
    color: var(--text-4); letter-spacing: -0.04em; margin-bottom: 12px;
  }
  .not-found p { font-size: 16px; color: var(--text-3); }
  .not-found a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
</style>
